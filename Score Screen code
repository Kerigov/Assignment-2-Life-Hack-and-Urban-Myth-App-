package com.example.lifehackorurbanmyth

import android.content.Intent
import androidx.appcompat.app.AppCompatActivity
import android.os.Bundle
import android.util.Log
import android.widget.Button
import android.widget.ProgressBar
import android.widget.TextView

class ScoreActivity : AppCompatActivity() {
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_score)
        
        val score = intent.getIntExtra("SCORE", 0)
        val total = intent.getIntExtra("TOTAL", 10)
        
        Log.d("ScoreActivity", "Score received: $score out of $total")
        
        val tvScore: TextView = findViewById(R.id.tvScore)
        val tvFeedback: TextView = findViewById(R.id.tvFeedback)
        val progressBar: ProgressBar = findViewById(R.id.progressBar)
        val btnReview: Button = findViewById(R.id.btnReview)
        val btnPlayAgain: Button = findViewById(R.id.btnPlayAgain)
        
        tvScore.text = "You scored $score out of $total!"
        
        // Personalised feedback based on score
        val feedback = when {
            score >= 8 -> "Master Hacker! You really know your life hacks!"
            score >= 6 -> "Great job! You know quite a few life hacks!"
            score >= 4 -> "Not bad! Keep learning to spot the myths."
            else -> "Stay Safe Online! Lots of myths caught you out this time."
        }
        
        tvFeedback.text = feedback
        Log.d("ScoreActivity", "Feedback shown: $feedback")
        
        progressBar.progress = (score.toFloat() / total * 100).toInt()
        
        // Navigation to Review screen
        btnReview.setOnClickListener {
            Log.d("ScoreActivity", "Review button tapped -- navigating to ReviewActivity")
            val intent = Intent(this, ReviewActivity::class.java)
            startActivity(intent)
        }
        
        // Navigation back to Welcome screen
        btnPlayAgain.setOnClickListener {
            Log.d("ScoreActivity", "Play Again tapped -- restarting quiz")
            val intent = Intent(this, WelcomeActivity::class.java)
            intent.flags = Intent.FLAG_ACTIVITY_CLEAR_TOP
            startActivity(intent)
            finish()
        }
    }
}
