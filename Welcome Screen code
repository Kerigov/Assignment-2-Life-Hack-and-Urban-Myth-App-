package com.example.lifehackorurbanmyth

import android.content.Intent
import androidx.appcompat.app.AppCompatActivity
import android.os.Bundle
import android.util.Log
import android.widget.Button
import android.widget.TextView

class WelcomeActivity : AppCompatActivity() {
    
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_welcome)
        
        Log.d("WelcomeActivity", "Welcome screen loaded successfully")
        
        val startButton: Button = findViewById(R.id.btnStart)
        startButton.setOnClickListener {
            Log.d("WelcomeActivity", "Start button tapped -- navigating to QuestionActivity")
            val intent = Intent(this, QuestionActivity::class.java)
            startActivity(intent)
        }
    }
}
